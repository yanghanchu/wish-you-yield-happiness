# ==============================
# Supabase 基础配置
# ==============================

# Supabase 项目 URL
# 在 Supabase 后台 Project Settings -> API 中找到 Project URL
# 示例：https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Supabase 可发布密钥
# 在 Supabase 后台 Project Settings -> API -> 可发布密钥 中复制
# 新版 Supabase 可能显示为 sb_publishable_ 开头
# 这个密钥可以用于浏览器前端
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase 服务端秘密密钥
# 在 Supabase 后台 Project Settings -> API -> 秘密密钥 中复制
# 新版 Supabase 可能显示为 sb_secret_ 开头
# 这个密钥只能用于服务端，不能暴露到浏览器
# 不要把它写到任何 NEXT_PUBLIC_ 开头的变量里
SUPABASE_SERVICE_ROLE_KEY=

# ==============================
# 网站基础配置
# ==============================

# 本地开发地址
# 本地开发时使用 http://localhost:3000
# 部署上线后改成你的正式域名，例如 https://your-domain.online
NEXT_PUBLIC_SITE_URL=http://localhost:3000
